<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Wedding Receptions — Gold Coast DJ Hire</title>
<meta name="description" content="Gold Coast DJ Hire wedding receptions — professional DJ services across the Gold Coast." />
<link rel="canonical" href="https://www.goldcoastdjhire.com.au/services/wedding.html" />
<link rel="stylesheet" href="../style.css" />
<style>
  .service-hero { position: relative; min-height: 60vh; display: flex; align-items: flex-end; justify-content: flex-start; overflow: hidden; padding: 2rem; }
  .service-hero-bg { display: none; }
  .service-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,13,13,0.95) 0%, rgba(13,13,13,0.3) 100%); z-index: 1; }
  .service-hero-content { position: relative; z-index: 2; max-width: 700px; padding-bottom: 3rem; padding-top: 8rem; }
  .service-hero-content .section-label { margin-bottom: 1rem; }
  .service-hero-content h1 { font-family: 'Georgia', serif; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: normal; font-style: italic; color: #fff; line-height: 1.1; }
  .service-info { background: var(--dark); }
  .service-info p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.9; max-width: 760px; }
  .timeline-section { background: var(--black); }
  .timeline { position: relative; max-width: 700px; margin: 3rem auto 0; padding-left: 2rem; }
  .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, #FF2D8B, #A020F0, #2060FF); }
  .timeline-item { position: relative; margin-bottom: 3rem; opacity: 0; transform: translateX(-30px); }
  .timeline-item:last-child { margin-bottom: 0; }
  .timeline-dot { position: absolute; left: -2.45rem; top: 0.25rem; width: 14px; height: 14px; border-radius: 50%; background: var(--gradient); border: 2px solid var(--black); flex-shrink: 0; }
  .timeline-content { background: var(--card); border: 1px solid var(--border); padding: 1.5rem; position: relative; overflow: hidden; }
  .timeline-content::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gradient); }
  .timeline-step { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.4rem; }
  .timeline-content h3 { font-family: 'Georgia', serif; font-size: 1.1rem; color: #fff; font-weight: normal; margin-bottom: 0.5rem; }
  .timeline-content p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.8; }
  .cta-section { background: var(--dark); text-align: center; }
  .cta-section p { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto; }
</style>
</head>
<body>
<!-- MOBILE MENU OVERLAY -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" onclick="closeMobile()">Home</a>
  <a href="/about" onclick="closeMobile()">About</a>
  <a href="/services" onclick="closeMobile()">Services</a>
  <a href="/blog" onclick="closeMobile()">Blog</a>
  <a href="/contact" class="mobile-cta" onclick="closeMobile()">Book Now</a>
  <a href="mailto:hello@goldcoastdjhire.com.au" class="mobile-email">hello@goldcoastdjhire.com.au</a>
</div>
<nav>
  <a href="/" class="nav-logo"><img src="../logo.svg" alt="Gold Coast DJ Hire" /></a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/services">Services</a></li>
    <li><a href="/blog">Blog</a></li>
    <li class="nav-cta"><a href="/contact">Book Now</a></li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Open menu"><span></span><span></span><span></span></button>
</nav>

<div class="service-hero">
  <div class="service-hero-bg">Add your Wedding Receptions cover photo here</div>
  <div class="service-hero-overlay"></div>
  <div class="service-hero-content">
    <p class="section-label">Weddings</p>
    <h1 class="grad-text">Wedding Receptions</h1>
  </div>
</div>

<section class="service-info">
  <div class="section-inner">
    <p class="section-label">Overview</p>
    <h2 class="section-title">What we <em class="grad-text">offer</em></h2>
    <div class="divider"></div>
    <p>Your wedding day is one of the most important days of your life, and the music is a huge part of what makes it unforgettable. We work closely with you to create a musical journey that's completely personal — from the moment your guests arrive to the last dance of the night. Every song, every transition, every moment is carefully considered.</p>
    <div style="margin-top:2rem;">
      <a href="/contact" class="btn-primary">Book This Service</a>
    </div>
  </div>
</section>

<section class="timeline-section">
  <div class="section-inner">
    <p class="section-label">The Process</p>
    <h2 class="section-title">How it <em class="grad-text">works</em></h2>
    <div class="divider"></div>
    <div class="timeline" id="timeline">

      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 1</div>
          <h3>First Enquiry</h3>
          <p>Tell us your date, venue and vision. We'll confirm our availability and arrange an initial consultation.</p>
        </div>
      </div>
      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 2</div>
          <h3>Wedding Consultation</h3>
          <p>We sit down with you (in person or online) to go through your music preferences, must-play songs, do-not-play list, and overall wedding vibe.</p>
        </div>
      </div>
      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 3</div>
          <h3>Booking Confirmed</h3>
          <p>A deposit locks in your date and we send through your wedding brief and timeline template for you to complete at your leisure.</p>
        </div>
      </div>
      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 4</div>
          <h3>Music Planning</h3>
          <p>4–6 weeks out we finalise your song list — ceremony songs, cocktail hour playlist, first dance, bridal party, cake cutting, and reception tracks.</p>
        </div>
      </div>
      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 5</div>
          <h3>Venue Coordination</h3>
          <p>We liaise directly with your venue and wedding coordinator to confirm setup times, power access, and the evening run sheet.</p>
        </div>
      </div>
      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 6</div>
          <h3>Wedding Day Setup</h3>
          <p>We arrive early — typically 2 hours before guests — to set up, soundcheck, and be completely ready well before you walk down the aisle.</p>
        </div>
      </div>
      <div class="timeline-item" style="opacity:0;transform:translateX(-30px);">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-step">Step 7</div>
          <h3>Your Perfect Day</h3>
          <p>From ceremony through to the final song, we handle every musical moment with care, energy and professionalism.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="section-inner">
    <p class="section-label">Ready?</p>
    <h2 class="section-title">Let's make it <em class="grad-text">happen</em></h2>
    <div class="divider" style="margin: 1rem auto 1.5rem;"></div>
    <p>Get in touch today and we'll put together a tailored package for your event.</p>
    <a href="/contact" class="btn-primary">Book a Consultation</a>
  </div>
</section>

<footer>
  <div class="footer-inner">
    <p>&copy; 2026 Gold Coast DJ Hire — All rights reserved.</p>
    <div class="footer-links">
      <a href="mailto:hello@goldcoastdjhire.com.au">hello@goldcoastdjhire.com.au</a>
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/contact">Contact</a>
    </div>
  </div>
</footer>
<div class="cookie-banner" id="cookieBanner">
  <p>We use cookies to analyse website traffic. See our <a href="mailto:hello@goldcoastdjhire.com.au">hello@goldcoastdjhire.com.au</a>
      <a href="/privacy-policy">Privacy Policy</a>.</p>
  <div class="cookie-buttons">
    <button class="btn-decline" onclick="declineCookies()">Decline</button>
    <button class="btn-accept" onclick="acceptCookies()">Accept</button>
  </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
<script>
  function onVisible(sel, cb) {
    const el = document.querySelector(sel);
    if (!el) return;
    const obs = new IntersectionObserver(e => { if (e[0].isIntersecting) { cb(); obs.disconnect(); } }, { threshold: 0.05 });
    obs.observe(el);
  }

  // Animate timeline items as they scroll into view
  const items = document.querySelectorAll('.timeline-item');
  items.forEach((item, i) => {
    const obs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        anime({ targets: item, opacity: [0,1], translateX: [-30,0], duration: 700, easing: 'easeOutExpo', delay: 100 });
        obs.disconnect();
      }
    }, { threshold: 0.3 });
    obs.observe(item);
  });

  window.addEventListener('load', () => { if (!localStorage.getItem('gc_cookie_consent')) setTimeout(() => document.getElementById('cookieBanner').classList.add('visible'), 1500); });
  function acceptCookies() { localStorage.setItem('gc_cookie_consent','accepted'); document.getElementById('cookieBanner').classList.remove('visible'); }
  function declineCookies() { localStorage.setItem('gc_cookie_consent','declined'); document.getElementById('cookieBanner').classList.remove('visible'); }
</script>
<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  function closeMobile() {
    mobileMenu.classList.remove('open');
    mobileMenu.style.display = 'none';
    hamburger.classList.remove('open');
    document.body.style.overflow = '';
  }
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    if (isOpen) {
      mobileMenu.style.display = 'flex';
      setTimeout(() => mobileMenu.classList.add('open'), 10);
      document.body.style.overflow = 'hidden';
    } else { closeMobile(); }
  });
</script>
</body>
</html>
